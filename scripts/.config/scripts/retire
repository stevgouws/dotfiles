#!/usr/bin/env bash
set -euo pipefail

dir=$(basename "$PWD")

if [ -z "$1" ]; then
  echo "Usage: retire <dir-name>"
  echo "Current directory: $dir"
  exit 1
fi

if [ "$1" != "$dir" ]; then
  echo "Error: '$1' does not match current directory '$dir'"
  exit 1
fi

git worktree remove "$dir"

osascript - "$dir" <<'APPLESCRIPT'
on run argv
	set targetTitle to item 1 of argv

	tell application "System Events"
		tell process "Code"
			set targetWindows to windows whose name is targetTitle
			repeat with w in targetWindows
				try
					click button 1 of w
				end try
			end repeat
		end tell
	end tell
end run
APPLESCRIPT

tmux switch-client -t dotfiles
tmux kill-session -t "$dir"
