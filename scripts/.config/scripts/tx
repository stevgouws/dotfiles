#!/usr/bin/env bash
set -euo pipefail

RUN_CMD=""
SESSION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --run) RUN_CMD="$2"; shift 2 ;;
    *)
      if [[ -z "$SESSION" ]]; then
        SESSION="$1"; shift
      else
        echo "Unknown argument: $1" >&2; exit 1
      fi
      ;;
  esac
done

SESSION="${SESSION:-dotfiles}"
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
PROJECT_TMUX_SETUP="$PROJECT_ROOT/.tmux-setup.sh"

if [[ -e "$PROJECT_TMUX_SETUP" && ! -x "$PROJECT_TMUX_SETUP" ]]; then
  echo "$PROJECT_TMUX_SETUP exists but is not executable" >&2
  exit 1
fi

if ! tmux has-session -t "=${SESSION}" 2>/dev/null; then
  tmux new-session -d -s "$SESSION" -c "$PROJECT_ROOT"

  if [[ -x "$PROJECT_TMUX_SETUP" ]]; then
    "$PROJECT_TMUX_SETUP" "$SESSION" "$PROJECT_ROOT"
  fi

  if [[ -n "$RUN_CMD" ]]; then
    tmux send-keys -t "=${SESSION}:1" "$RUN_CMD" Enter
  fi
fi

code "$PROJECT_ROOT"
# If already in TMUX don't nest, just switch
if [[ -n "${TMUX:-}" ]]; then
  exec tmux switch-client -t "=${SESSION}"
else
  exec tmux attach -t "=${SESSION}"
fi
