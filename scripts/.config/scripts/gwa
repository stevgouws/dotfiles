#!/usr/bin/env zsh
set -euo pipefail

name=""
branch_name=""
base_branch="origin/main"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --branch-name) branch_name="$2"; shift 2 ;;
    --base-branch) base_branch="$2"; shift 2 ;;
    *)
      if [[ -z "$name" ]]; then
        name="$1"; shift
      else
        echo "Unknown argument: $1" >&2; exit 1
      fi
      ;;
  esac
done

if [[ -z "$name" ]]; then
  echo "Usage: gwa <name> [--branch-name <branch>] [--base-branch <branch>]" >&2
  exit 1
fi

branch_name="${branch_name:-$name}"
dir_name="$name"
main_worktree="$(git rev-parse --show-toplevel)"
project_name="$(basename "$main_worktree")"
worktree_dir="$HOME/projects/worktrees/$project_name/$dir_name"

# 1) Local branch already exists
if git show-ref --verify --quiet "refs/heads/$branch_name"; then
  echo "Local branch '$branch_name' exists, adding worktree for it..."
  git worktree add "$worktree_dir" "$branch_name"

# 2) Remote branch exists on origin (but not locally)
elif git ls-remote --exit-code --heads origin "$branch_name" >/dev/null 2>&1; then
  echo "Remote branch 'origin/$branch_name' exists, creating local branch from it..."
  git worktree add "$worktree_dir" -b "$branch_name" "origin/$branch_name"

# 3) Brand new branch – create from base branch
else
  echo "Branch '$branch_name' does not exist locally or on origin, creating from $base_branch..."
  git worktree add --no-track "$worktree_dir" -b "$branch_name" "$base_branch"
fi

cd "$worktree_dir"

cp "$main_worktree/.tmux-setup.sh" . 2>/dev/null || true
cp "$main_worktree/.worktree-setup.sh" . 2>/dev/null || true

if [[ -x "$worktree_dir/.worktree-setup.sh" ]]; then
  exec ~/.config/scripts/tx "$dir_name" --run "./.worktree-setup.sh"
else
  exec ~/.config/scripts/tx "$dir_name"
fi
